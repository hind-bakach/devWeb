<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- Barre du haut avec flèche retour -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#4F46E5"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/btnRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@android:color/transparent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Détail véhicule"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Infos du véhicule + bouton sauvegarder -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvDetailMarque"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDetailModele"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#334155"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDetailAnnee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#334155"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDetailImmat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#334155"
            android:layout_marginBottom="12dp"/>

        <!-- Statut de la position sauvegardée -->
        <TextView
            android:id="@+id/tvStatutPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aucune position sauvegardée"
            android:textSize="13sp"
            android:textColor="#64748B"
            android:layout_marginBottom="8dp"/>

        <!-- Bouton sauvegarder la position du véhicule -->
        <Button
            android:id="@+id/btnSauvegarderPosition"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sauvegarder la position du véhicule ici"
            android:textSize="14sp"
            android:backgroundTint="#10B981"/>

    </LinearLayout>

    <!-- Légende -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔴 Voiture   🔵 Moi"
            android:textSize="13sp"
            android:textColor="#64748B"/>

    </LinearLayout>

    <!-- Carte osmdroid -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>